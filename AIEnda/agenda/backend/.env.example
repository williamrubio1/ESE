# ─── Zona horaria ────────────────────────────────────────────────────────────
TZ=America/Bogota

# ─── Servidor ─────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET=CAMBIA_ESTO_POR_UN_SECRETO_SEGURO
JWT_EXPIRES_IN=8h

# ─── Base de datos MySQL ──────────────────────────────────────────────────────
DB_HOST=
DB_PORT=3306
DB_USER=
DB_PASSWORD=
DB_NAME=

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_HOST=
REDIS_PORT=6379
REDIS_PASSWORD=

# ─── Correo (recuperación de contraseña) ─────────────────────────────────────
MAIL_HOST=
MAIL_PORT=587
MAIL_USER=
MAIL_PASSWORD=
MAIL_FROM=
